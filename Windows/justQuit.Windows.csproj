<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0-windows</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <UseWPF>true</UseWPF>
    <UseWindowsForms>true</UseWindowsForms>
    <AssemblyName>justQuit</AssemblyName>
    <RootNamespace>justQuit.Windows</RootNamespace>
    <Version>1.2.09</Version>
    <AssemblyVersion>1.2.9.0</AssemblyVersion>
    <FileVersion>1.2.9.0</FileVersion>
    <Company>Agraja</Company>
    <Authors>Agraja</Authors>
    <Product>justQuit</Product>
    <ApplicationIcon>assets\AppIcon.ico</ApplicationIcon>
  </PropertyGroup>

  <ItemGroup>
    <Content Include="assets\AppIcon.ico">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>
  </ItemGroup>

</Project>
